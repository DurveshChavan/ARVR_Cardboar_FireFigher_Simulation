<?xml version="1.0" encoding="utf-8"?>
<!--
  Minimal manifest — only declares what Unity and the Cardboard AAR do NOT already provide.
  The Cardboard AAR manifest merges in QrCodeCaptureActivity and HeadsetDetectionActivity.
  Unity's generated launcher manifest adds INTERNET, VIBRATE, and other standard permissions.
  We only need to swap the main activity to CardboardUnityPlayerActivity to fix the JNI
  classloader crash (java_class == null in RegisterNatives).
-->
<manifest
    xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.unity3d.player"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Camera permission needed for Cardboard QR scanner (Unity doesn't add this by default) -->
    <uses-permission android:name="android.permission.CAMERA"/>

    <!-- OpenGL ES 3.0 required by Cardboard rendering -->
    <uses-feature android:glEsVersion="0x00030000" android:required="true"/>

    <!-- Camera hardware feature for QR scanner (not required — graceful fallback if no camera) -->
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <uses-feature android:name="android.hardware.camera.autofocus" android:required="false"/>

    <application>

        <!--
            Override the main activity to CardboardUnityPlayerActivity.
            This pre-loads libGfxPluginCardboard.so with the APPLICATION classloader,
            so that JNI_OnLoad can resolve com.google.cardboard.sdk.qrcode.* via
            FindClass() — fixing the SIGABRT crash on launch.
        -->
        <activity
            android:name="com.unity3d.player.CardboardUnityPlayerActivity"
            android:screenOrientation="fullSensor"
            android:launchMode="singleTask"
            android:configChanges="mcc|mnc|locale|touchscreen|keyboard|keyboardHidden|navigation|orientation|screenLayout|uiMode|screenSize|smallestScreenSize|fontScale|layoutDirection|density"
            android:hardwareAccelerated="false"
            android:theme="@android:style/Theme.Black.NoTitleBar.Fullscreen"
            android:exported="true"
            tools:node="replace">
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>

    </application>
</manifest>
